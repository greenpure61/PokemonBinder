# Copy to .env.local and fill in. All values below are validated at startup by
# src/lib/env.ts — the app fails fast with a clear message if any are missing.

# PostgreSQL connection string used by the app at runtime. On serverless (Vercel)
# this MUST be a *pooled* connection, or concurrent functions will exhaust the
# Postgres connection limit under load. On Neon, use the "Pooled connection"
# string — its host contains "-pooler" (PgBouncer), e.g.
#   postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host-pooler:5432/dbname?sslmode=require"

# Direct (NON-pooled) connection, used only by Prisma migrations / schema commands
# (DDL doesn't work through PgBouncer's transaction pooler). On Neon this is the
# "Direct connection" string — the same host WITHOUT "-pooler". Optional for local
# dev against a single non-pooled database (falls back to DATABASE_URL).
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Google OAuth credentials (console.cloud.google.com → Credentials → OAuth client).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Secret used by NextAuth to sign sessions. Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Canonical app URL — used to build Google OAuth callback URLs. Locally this is
# http://localhost:3000. In production set it to your real https domain (NextAuth
# v4 does not reliably infer it), and make sure that exact origin's callback,
# https://<domain>/api/auth/callback/google, is an Authorized redirect URI in the
# Google OAuth client.
NEXTAUTH_URL="http://localhost:3000"

# Note: card data comes from the public TCGdex API — no API key required.
